# ─────────────────────────────────────────────────────────────────────────────
# Hlíðarkaup — environment template
#
# Copy this file to `.env.local` and fill in the blanks. `.env.local` is
# gitignored and MUST NEVER be committed. Values left blank below are secrets
# or environment-specific credentials — obtain them from the relevant provider.
# Non-secret defaults (public URLs, ports, feature flags, model names) are kept
# as sensible starting values.
# ─────────────────────────────────────────────────────────────────────────────

# Teya Payment Gateway — fill in when you have credentials
TEYA_API_KEY=
TEYA_SECRET=
TEYA_MERCHANT_ID=

# Straumur card terminal (wired on the LAN, addressed by IP). Leave IP blank to
# run the till in MOCK mode (auto-approves) until the terminal is connected.
STRAUMUR_TERMINAL_IP=
STRAUMUR_TERMINAL_PORT=
# STRAUMUR_TIMEOUT_MS=120000
# STRAUMUR_MOCK=true        # force mock even if an IP is set
# Regla payment-method IDs for till sales (card defaults to KASSI_PAYMENT_METHOD_ID=76)
# POSI_CARD_PAYMENT_METHOD_ID=76
# POSI_CASH_PAYMENT_METHOD_ID=1
# Regla "á reikning" (credit) payment-method ID for account sales — set the real
# one from Regla; until then account sales fall back to the card method ID.
# POSI_ACCOUNT_PAYMENT_METHOD_ID=

# Your deployed URL (update before going live)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://hlidarkaup.netlify.app

# Product API (replace with your real endpoint)
PRODUCT_API_URL=
PRODUCT_API_KEY=

# Google Maps — browser key; restrict by HTTP referrer in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Kenni — Icelandic OIDC authentication (register at kenni.is)
KENNI_CLIENT_ID=
KENNI_CLIENT_SECRET=
KENNI_REDIRECT_URI=http://localhost:3000/api/auth/kenni/callback
SJALFSALI_MIN_AGE=18

# UniFi Access — vending machine door control
UNIFI_HOST=https://192.168.0.1:12445
UNIFI_CONSOLE_HOST=https://192.168.0.1
UNIFI_API_TOKEN=
UNIFI_ACCESS_GROUP_ID=
UNIFI_USERNAME=
UNIFI_PASSWORD=
MAC_LOCAL_IP=

# Regla accounting system
REGLA_USERNAME=
REGLA_PASSWORD=
REGLA_BASE_URL=https://www.regla.is/fibs/RestAPI2019

# Self-hosted Postgres (accounting + catalog). Local dev = local cluster on :5455.
DATABASE_URL=postgres://postgres@127.0.0.1:5455/hlidarkaup

# Staff/back-office auth. STAFF_PASSWORD = shared break-glass login (any email);
# real per-user login validates against Supabase staff accounts.
# STAFF_SESSION_SECRET must be a long random string in production.
STAFF_PASSWORD=
STAFF_SESSION_SECRET=

# Arion B2B/Business API (bankatenging). Fill in after Arion onboarding — see
# deploy/ARION_ONBOARDING.md. Use a DEDICATED netbank user with limited access.
ARION_USERNAME=
ARION_PASSWORD=
ARION_SUBSCRIPTION_KEY=
ARION_CERT_PATH=
ARION_CERT_PASSWORD=
# Optional overrides (defaults are production):
# ARION_TOKEN_URL=https://apigw.arionbanki.is/oauth/v2/oauth-token
# ARION_BASE_URL=https://apigw.arionbanki.is
# ARION_SCOPE=openid b2b
# ARION_SANDBOX=true

# Claude (Anthropic) — reads PDF invoices on the Skráning page. Get a key at
# console.anthropic.com → API Keys. Optional: SKRANING_MODEL (default claude-haiku-4-5).
ANTHROPIC_API_KEY=
# Kennitala used as the generic web-shop customer in Regla
# (for production use the store's own kennitala or ask Regla)
REGLA_WEB_CUSTOMER_KENNITALA=
# TESTING ONLY: skip stock limits on the self-checkout kiosk. Keep false for production!
KASSI_IGNORE_STOCK=false
# Bag product (BURÐARPOKI) offered before payment on the kiosk
KASSI_BAG_PRODUCT=

# Resend — e-receipt (rafræn kvittun) email. Get the key at resend.com (API Keys).
RESEND_API_KEY=
# Sender. Until hlidarkaup.is is verified in Resend, use: Hlíðarkaup <onboarding@resend.dev>
# (test sender only delivers to your own Resend account email). After verifying the
# domain, switch to e.g. Hlíðarkaup <kvittun@hlidarkaup.is>
RECEIPT_FROM=Hlíðarkaup <onboarding@resend.dev>
# Set to "true" on Netlify to turn the e-receipt button on in production (local dev: always on)
NEXT_PUBLIC_ERECEIPT_ENABLED=true

# Supabase — SVO GOTT menu backend.
# URL: Supabase → Settings → Data API → Project URL (https://<ref>.supabase.co)
# KEY: the "Publishable key" (sb_publishable_...). NOT the secret key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (Supabase → Settings → API → Secret keys, sb_secret_...). SERVER ONLY.
# Needed only so managers can create staff accounts from /starf/admin. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft 365 (Graph) — sjálfvirk skráning reikninga úr tölvupósti (Pósthólf).
# App-only (client credentials), READ-ONLY (Mail.Read, scoped to one mailbox via
# Exchange Application Access Policy). See deploy/EMAIL_ONBOARDING.md.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX=
# Shared secret for the unattended cron poll (/api/cron/email-poll).
EMAIL_POLL_SECRET=

# Skráning invoice-reader model (haiku misreads scanned invoices; Sonnet reads them correctly).
SKRANING_MODEL=claude-sonnet-4-6

# inExchange (rafrænir reikningar) — RECEIVE via SOAP (ws.inexchange.is/OutgoingInvoices/sksk.asmx).
# Password comes from the one-time-secret link inExchange emailed — paste it into INEXCHANGE_PASSWORD.
INEXCHANGE_RECEIVE_URL=https://ws.inexchange.is/OutgoingInvoices/sksk.asmx
INEXCHANGE_USERNAME=
INEXCHANGE_PASSWORD=
INEXCHANGE_RECEIVER_ID=
INEXCHANGE_STANDARD=
INEXCHANGE_TRANSACTION_TYPE=
INEXCHANGE_ACK_STATUS=
INEXCHANGE_WEBHOOK_SECRET=

# inExchange SEND (rafrænir sölureikningar) — reuses INEXCHANGE_USERNAME/PASSWORD.
INEXCHANGE_SEND_URL=https://ws.inexchange.is/InvoiceService/InExchange.InvoiceService.InvoiceService.svc
INEXCHANGE_SUBACCOUNT=
INEXCHANGE_SEND_ENABLED=false

# Straumur / Adyen test terminal (P5)
ADYEN_POI_ID=
ADYEN_MERCHANT_ACCOUNT=
ADYEN_TERMINAL_ENV=test
ADYEN_API_KEY=
