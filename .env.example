# ─────────────────────────────────────────────────────────────────────────────
# Hlíðarkaup — environment template
#
# Copy this file to `.env.local` and fill in the blanks. `.env.local` is
# gitignored and MUST NEVER be committed. Values left blank below are secrets
# or environment-specific credentials — obtain them from the relevant provider.
# Non-secret defaults (public URLs, ports, feature flags, model names) are kept
# as sensible starting values.
# ─────────────────────────────────────────────────────────────────────────────

# Teya Payment Gateway — fill in when you have credentials
TEYA_API_KEY=
TEYA_SECRET=
TEYA_MERCHANT_ID=

# Straumur card terminal (wired on the LAN, addressed by IP). Leave IP blank to
# run the till in MOCK mode (auto-approves) until the terminal is connected.
STRAUMUR_TERMINAL_IP=
STRAUMUR_TERMINAL_PORT=
# STRAUMUR_TIMEOUT_MS=120000
# STRAUMUR_MOCK=true        # force mock even if an IP is set
# Regla payment-method IDs for till sales (card defaults to KASSI_PAYMENT_METHOD_ID=76)
# POSI_CARD_PAYMENT_METHOD_ID=76
# POSI_CASH_PAYMENT_METHOD_ID=1
# Regla "á reikning" (credit) payment-method ID for account sales — set the real
# one from Regla; until then account sales fall back to the card method ID.
# POSI_ACCOUNT_PAYMENT_METHOD_ID=

# Your deployed URL (update before going live)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://hlidarkaup.netlify.app

# Product API (replace with your real endpoint)
PRODUCT_API_URL=
PRODUCT_API_KEY=

# Google Maps — browser key; restrict by HTTP referrer in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Kenni — Icelandic OIDC authentication (register at kenni.is)
KENNI_CLIENT_ID=
KENNI_CLIENT_SECRET=
KENNI_REDIRECT_URI=http://localhost:3000/api/auth/kenni/callback
SJALFSALI_MIN_AGE=18

# UniFi Access — vending machine door control
UNIFI_HOST=https://192.168.0.1:12445
UNIFI_CONSOLE_HOST=https://192.168.0.1
UNIFI_API_TOKEN=
UNIFI_ACCESS_GROUP_ID=
UNIFI_USERNAME=
UNIFI_PASSWORD=
MAC_LOCAL_IP=

# Regla accounting system
REGLA_USERNAME=
REGLA_PASSWORD=
REGLA_BASE_URL=https://www.regla.is/fibs/RestAPI2019

# Self-hosted Postgres (accounting + catalog). Local dev = local cluster on :5455.
DATABASE_URL=postgres://postgres@127.0.0.1:5455/hlidarkaup

# Staff/back-office auth. STAFF_PASSWORD = shared break-glass login (any email);
# real per-user login validates against Supabase staff accounts.
# STAFF_SESSION_SECRET must be a long random string in production.
STAFF_PASSWORD=
STAFF_SESSION_SECRET=
# Production: back office (bókhald/kassi-starf/admin + staff login) reachable ONLY from the
# store LAN / VPN — requests arriving through the Cloudflare tunnel get 404. See DEPLOYMENT.md §5b.
ADMIN_LAN_ONLY=false

# Temporary allowlist: external IPs permitted to reach the in-store TILL over the tunnel (HTTPS)
# for remote peripheral testing (printer / skúffa / scanner / scale). Comma-separated. Scoped to
# the /kassi tree + staff login only — bókhald/admin stay LAN-only. Matched against Cloudflare's
# CF-Connecting-IP (unspoofable for tunnel traffic). LEAVE EMPTY normally; clear it when done testing.
KASSI_REMOTE_ALLOW_IPS=

# ── Arion B2B/Business API (bankatenging) ─────────────────────────────────────
# Fill in after Arion onboarding — see deploy/ARION_ONBOARDING.md.
# Auth (production): DEDICATED netbank user + búnaðarskilríki (.pfx OUTSIDE the repo!).
ARION_USERNAME=
ARION_PASSWORD=
ARION_CERT_PATH=
ARION_CERT_PASSWORD=
# Subscription keys — THREE SEPARATE PRODUCTS in the developer portal (one key each):
ARION_SUBSCRIPTION_KEY=            # Cards
ARION_PSD2_SUBSCRIPTION_KEY=       # PSD2 (Accounts + Payments)
ARION_CLAIMS_SUBSCRIPTION_KEY=     # Claims (innheimta)
# PSD2 — REQUIRED in production:
ARION_REDIRECT_URI=                # registered SCA return URL, e.g. https://<site>/bokhald/bankatenging
ARION_PSU_ID=                      # kennitala netbankanotandans (consents + payments)
# Claims go-live switch (leave false until innheimtusamningur + kröfusnið exist):
ARION_CLAIMS_ENABLED=false
# Sandbox only:
# ARION_SANDBOX=true
# ARION_ACCESS_TOKEN=              # portal "Generate Token" (sandbox ONLY — ignored in production)
# Optional overrides (defaults are correct for production):
# ARION_TOKEN_URL=https://apigw.arionbanki.is/oauth/v2/oauth-token
# ARION_BASE_URL=https://apigw.arionbanki.is
# ARION_SCOPE=openid b2b
# ARION_CARDS_PATH=/cards/api/v1/cards
# ARION_CARD_TX_PATH=/cards/api/v1/cards/{id}/transactions
# ARION_PSD2_PATH=/psd2/api/v1
# ARION_PAYMENT_PRODUCT=sepa-credit-transfers   # CONFIRM ISK product string with Arion
# ARION_CLAIMS_API_PATH=/claims/api/v1          # CONFIRM path with Arion

# ── Arion/RB B2B — ógreiddar kröfur Á OKKUR (BillService via B2B Bridge) ───────
# Shows bills OTHERS issue against us in the bank (we = payor). Needs the B2B Bridge on a
# Windows host (the till PC) — see deploy/ARION_B2B_BRIDGE.md. Only the URL is required to enable.
ARION_B2B_BRIDGE_URL=              # ClearUsernameBinding endpoint of the Bridge, e.g. http://192.168.1.NN:8080/BillService.svc
# ARION_B2B_USERNAME=             # defaults to ARION_USERNAME (B2B user)
# ARION_B2B_PASSWORD=             # defaults to ARION_PASSWORD
# ARION_B2B_PAYOR_ID=6507250420   # our kt; defaults to ARION_PSU_ID
# Statements (hreyfingaryfirlit) + payments via the same Bridge (real upstream versions are
# /Statements/20131015/AccountService.svc and /Payments/20131015/PaymentService.svc):
ARION_B2B_ACCOUNTS_URL=            # Bridge endpoint for AccountService (GetAccountStatement)
ARION_B2B_PAYMENTS_URL=            # Bridge endpoint for PaymentService (DoPayment — REAL MONEY)
ARION_B2B_DEBIT_ACCOUNT=           # 12-digit útgreiðslureikningur (útibú4+höfuðbók2+reikn6), e.g. 030326xxxxxx

# Claude (Anthropic) — reads PDF invoices on the Skráning page. Get a key at
# console.anthropic.com → API Keys. Optional: SKRANING_MODEL (default claude-haiku-4-5).
ANTHROPIC_API_KEY=
# Kennitala used as the generic web-shop customer in Regla
# (for production use the store's own kennitala or ask Regla)
REGLA_WEB_CUSTOMER_KENNITALA=
# TESTING ONLY: skip stock limits on the self-checkout kiosk. Keep false for production!
KASSI_IGNORE_STOCK=false

# ── Network receipt printer (Volcora, ESC/POS over TCP 9100) ────────────────
# The SERVER prints — no software needed on the till PC. Per-register printers
# (same pattern as ADYEN_POIID_<REG>), falling back to the shared PRINTER_IP.
# The cash drawer is kicked through the printer (ESC p).
# PRINTER_IP=192.168.1.200            # shared fallback ([host] or [host:port])
# PRINTER_IP_KASSI1=192.168.1.200     # per-register
# PRINTER_PORT=9100                   # default 9100
# PRINTER_CODEPAGE=16                 # ESC t n for Icelandic; 16=WPC1252 (Epson), NCR used 8
# Bag product (BURÐARPOKI) offered before payment on the kiosk
KASSI_BAG_PRODUCT=

# Resend — e-receipt (rafræn kvittun) email. Get the key at resend.com (API Keys).
RESEND_API_KEY=
# Sender. Until hlidarkaup.is is verified in Resend, use: Hlíðarkaup <onboarding@resend.dev>
# (test sender only delivers to your own Resend account email). After verifying the
# domain, switch to e.g. Hlíðarkaup <kvittun@hlidarkaup.is>
RECEIPT_FROM=Hlíðarkaup <onboarding@resend.dev>
# Set to "true" on Netlify to turn the e-receipt button on in production (local dev: always on)
NEXT_PUBLIC_ERECEIPT_ENABLED=true

# Supabase — SVO GOTT menu backend.
# URL: Supabase → Settings → Data API → Project URL (https://<ref>.supabase.co)
# KEY: the "Publishable key" (sb_publishable_...). NOT the secret key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (Supabase → Settings → API → Secret keys, sb_secret_...). SERVER ONLY.
# Needed only so managers can create staff accounts from /starf/admin. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft 365 (Graph) — sjálfvirk skráning reikninga úr tölvupósti (Pósthólf).
# App-only (client credentials), READ-ONLY (Mail.Read, scoped to one mailbox via
# Exchange Application Access Policy). See deploy/EMAIL_ONBOARDING.md.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX=
# Shared secret for the unattended cron poll (/api/cron/email-poll).
EMAIL_POLL_SECRET=
# Shared secret for the unattended claims flush (/api/cron/claims) — sends queued
# kröfur to Arion + syncs payments. ALSO guards /api/cron/reminders (daily "EKKI GLEYMA"
# escalation email). Schedule: 0 8 * * * (claims), 0 9 * * * (reminders).
CLAIMS_CRON_SECRET=

# Áminningar-escalation email (/api/cron/reminders) — who gets "EKKI GLEYMA AÐ BÓKA FÆRSLUNA"
# when something critical is overdue/today. Comma-separated; defaults to the two below.
REMINDER_EMAIL_TO=oli@hlidarkaup.is,hlidarkaup@hlidarkaup.is
# Base URL used to build "Opna í kerfinu →" links inside that email (e.g. http://192.168.1.70:3000).
APP_BASE_URL=
# In-app assistant model (💬 helper, bottom-right of bókhald). Default claude-opus-4-8.
ASSISTANT_MODEL=claude-opus-4-8

# Skráning invoice-reader model (haiku misreads scanned invoices; Sonnet reads them correctly).
SKRANING_MODEL=claude-sonnet-4-6

# inExchange (rafrænir reikningar) — RECEIVE via SOAP (ws.inexchange.is/OutgoingInvoices/sksk.asmx).
# Password comes from the one-time-secret link inExchange emailed — paste it into INEXCHANGE_PASSWORD.
INEXCHANGE_RECEIVE_URL=https://ws.inexchange.is/OutgoingInvoices/sksk.asmx
INEXCHANGE_USERNAME=
INEXCHANGE_PASSWORD=
INEXCHANGE_RECEIVER_ID=
INEXCHANGE_STANDARD=
INEXCHANGE_TRANSACTION_TYPE=
INEXCHANGE_ACK_STATUS=
INEXCHANGE_WEBHOOK_SECRET=

# inExchange SEND (rafrænir sölureikningar) — reuses INEXCHANGE_USERNAME/PASSWORD.
INEXCHANGE_SEND_URL=https://ws.inexchange.is/InvoiceService/InExchange.InvoiceService.InvoiceService.svc
INEXCHANGE_SUBACCOUNT=
INEXCHANGE_SEND_ENABLED=false

# Straumur / Adyen test terminal (P5)
ADYEN_POI_ID=
ADYEN_MERCHANT_ACCOUNT=
ADYEN_TERMINAL_ENV=test
ADYEN_API_KEY=
